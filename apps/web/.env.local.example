# Supabase (get from https://supabase.com/dashboard/project/<project>/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Helux API (Render URL — update after first deploy)
NEXT_PUBLIC_API_URL=https://helux-api.onrender.com
# For local development: NEXT_PUBLIC_API_URL=http://localhost:3001
